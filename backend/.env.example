# Server Configuration
PORT=5000
NODE_ENV=development

# Database - REQUIRED
MONGODB_URI=mongodb://localhost:27017/finflow
DATABASE_URL="mongodb://localhost:27017/finflow"

# Authentication - REQUIRED
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration - REQUIRED
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM="FinFlow Support <your-email@gmail.com>"

# Frontend URL - REQUIRED (used for CORS and email links)
# IMPORTANT: Must match the exact port where frontend runs
FRONTEND_URL=http://localhost:5173

# File Upload Settings
MAX_FILE_SIZE=10485760

# AI Configuration
GEMINI_API_KEY="your-gemini-api-key"

# K-Pay Configuration
KPAY_API_KEY=your_kpay_api_key
KPAY_USERNAME=your_kpay_username
KPAY_PASSWORD=your_kpay_password
KPAY_RETAILER_ID=your_kpay_retailer_id
