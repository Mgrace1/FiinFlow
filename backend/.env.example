# Server Configuration
PORT=5000
NODE_ENV=development

# Database - REQUIRED
MONGODB_URI=mongodb://localhost:27017/finflow
DATABASE_URL="mongodb://localhost:27017/finflow"

# Authentication - REQUIRED
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration - REQUIRED
EMAIL_HOST=smtp.gmail.com
# Optional secondary SMTP host, used if primary times out
EMAIL_HOST_FALLBACK=
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM="FinFlow Support <your-email@gmail.com>"
EMAIL_REPLY_TO=
# Optional: if set, backend uses Resend API first, then SMTP fallback
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
# Optional sender specifically for Resend (must be verified in Resend)
RESEND_FROM=
# Set true to avoid SMTP timeout fallback when Resend is configured
EMAIL_DISABLE_SMTP_FALLBACK=false
EMAIL_CONNECTION_TIMEOUT=10000
EMAIL_GREETING_TIMEOUT=10000
EMAIL_SOCKET_TIMEOUT=20000

# Frontend URL - REQUIRED (used for CORS and email links)
# IMPORTANT: Must match the exact port where frontend runs
FRONTEND_URL=http://localhost:5173

# File Upload Settings
MAX_FILE_SIZE=10485760

# Super Admin Bootstrap (optional, used by: npm run create:super-admin)
SUPER_ADMIN_NAME=Platform Super Admin
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
# Optional: force the company/workspace this super admin belongs to
SUPER_ADMIN_COMPANY_ID=
