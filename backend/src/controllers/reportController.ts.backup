import { Response } from 'express';
import PDFDocument from 'pdfkit';
import { AuthRequest } from '../middleware/auth';
import { Company, Invoice, Expense } from '../models';
import path from 'path';
import fs from 'fs';

/**
 * Helper function to add company header to PDF
 */
const addCompanyHeader = (
  doc: PDFKit.PDFDocument,
  company: any,
  title: string
) => {
  const brandColor = company.brandColor || '#2563EB';
  const displayName = company.displayName || company.name;

  // Add logo if available
  if (company.logoUrl) {
    try {
      const logoPath = path.join(__dirname, '../../uploads/company-logos', path.basename(company.logoUrl));
      if (fs.existsSync(logoPath)) {
        doc.image(logoPath, 50, 45, { width: 60 });
      }
    } catch (error) {
      console.error('Error loading logo:', error);
    }
  }

  // Company name
  doc.fontSize(18).fillColor(brandColor).font('Helvetica-Bold');
  doc.text(displayName, 120, 50, { align: 'left' });

  // Document title
  doc.fontSize(14).fillColor('#000000');
  doc.text(title, 400, 50, { align: 'right' });

  // Divider line
  doc.moveTo(50, 90).lineTo(550, 90).strokeColor(brandColor).lineWidth(2).stroke();

  return doc;
};

/**
 * Helper function to add footer
 */
const addFooter = (doc: PDFKit.PDFDocument, company: any, pageNum: number = 1) => {
  const footerText = company.invoiceFooterText || 'Thank you for your business!';
  const today = new Date();
  const formattedDate = `${today.getDate().toString().padStart(2, '0')}-${(today.getMonth() + 1).toString().padStart(2, '0')}-${today.getFullYear()}`;

  doc.fontSize(10).fillColor('#666666').font('Helvetica-Oblique');
  doc.text(footerText, 50, 720, { align: 'center', width: 500 });
  doc.fontSize(8).fillColor('#999999').font('Helvetica');
  doc.text(`Generated on: ${formattedDate} | Page ${pageNum}`, 50, 740, { align: 'center', width: 500 });
};

/**
 * Generate Invoice PDF
 */
export const generateInvoicePDF = async (req: AuthRequest, res: Response) => {
  try {
    const { invoiceId } = req.params;

    // Fetch invoice with populated fields
    const invoice = await Invoice.findById(invoiceId)
      .populate('clientId')
      .populate('createdBy')
      .populate({
        path: 'attachments.fileId',
        model: 'File',
      })
      .populate({
        path: 'attachments.uploadedBy',
        model: 'User',
      });

    if (!invoice) {
      return res.status(404).json({
        success: false,
        error: 'Invoice not found',
      });
    }

    // Permission check
    const userRole = req.userRole;
    if (userRole === 'staff' && invoice.createdBy?._id?.toString() !== req.userId) {
      return res.status(403).json({
        success: false,
        error: 'You can only download invoices you created',
      });
    }

    // Fetch company
    const company = await Company.findById(req.companyId);
    if (!company) {
      return res.status(404).json({
        success: false,
        error: 'Company not found',
      });
    }

    // Create PDF document
    const doc = new PDFDocument({ margin: 50, size: 'A4' });

    // Set response headers
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader(
      'Content-Disposition',
      `attachment; filename=invoice-${invoice.invoiceNumber}.pdf`
    );

    // Pipe PDF to response
    doc.pipe(res);

    // Add header
    addCompanyHeader(doc, company, `Invoice #${invoice.invoiceNumber}`);

    doc.moveDown(2);

    // Invoice Status Badge
    const statusColors: any = {
      draft: '#6B7280',
      sent: '#3B82F6',
      paid: '#10B981',
      overdue: '#EF4444',
      cancelled: '#6B7280',
    };
    const statusColor = statusColors[invoice.status] || '#6B7280';

    doc.fontSize(12).fillColor(statusColor).font('Helvetica-Bold');
    doc.text(`Status: ${invoice.status.toUpperCase()}`, 50, doc.y);
    doc.moveDown(1.5);

    // Invoice Information
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text('Invoice Details', 50, doc.y);
    doc.moveDown(0.5);

    doc.fontSize(11).fillColor('#000000').font('Helvetica');
    const clientName = (invoice.clientId as any)?.name || 'N/A';
    const clientEmail = (invoice.clientId as any)?.email || 'N/A';

    doc.text(`Client: ${clientName}`, 50, doc.y);
    doc.text(`Email: ${clientEmail}`, 50, doc.y);
    doc.text(`Invoice Date: ${new Date(invoice.createdAt).toLocaleDateString('en-GB')}`, 50, doc.y);
    doc.text(`Due Date: ${new Date(invoice.dueDate).toLocaleDateString('en-GB')}`, 50, doc.y);

    if (invoice.sentAt) {
      doc.text(`Sent: ${new Date(invoice.sentAt).toLocaleDateString('en-GB')}`, 50, doc.y);
    }
    if (invoice.paidAt) {
      doc.text(`Paid: ${new Date(invoice.paidAt).toLocaleDateString('en-GB')}`, 50, doc.y);
    }

    doc.moveDown(1.5);

    // Amount Section
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text('Amount Breakdown', 50, doc.y);
    doc.moveDown(0.5);

    doc.fontSize(11).fillColor('#000000').font('Helvetica');
    doc.text(`Subtotal: ${invoice.amount.toLocaleString()} ${invoice.currency}`, 50, doc.y);

    if (invoice.taxApplied) {
      const taxAmount = invoice.totalAmount - invoice.amount;
      doc.text(`Tax (${invoice.taxRate}%): ${taxAmount.toLocaleString()} ${invoice.currency}`, 50, doc.y);
    }

    doc.fontSize(12).font('Helvetica-Bold');
    doc.text(`Total: ${invoice.totalAmount.toLocaleString()} ${invoice.currency}`, 50, doc.y);
    doc.moveDown(1.5);

    // Description and Notes
    if (invoice.description) {
      doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
      doc.text('Description', 50, doc.y);
      doc.moveDown(0.5);
      doc.fontSize(11).fillColor('#000000').font('Helvetica');
      doc.text(invoice.description, 50, doc.y, { width: 500 });
      doc.moveDown(1);
    }

    if (invoice.notes) {
      doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
      doc.text('Notes', 50, doc.y);
      doc.moveDown(0.5);
      doc.fontSize(11).fillColor('#000000').font('Helvetica-Oblique');
      doc.text(invoice.notes, 50, doc.y, { width: 500 });
      doc.moveDown(1);
    }

    // Payment Information (if paid)
    if (invoice.status === 'paid' && invoice.paymentMethod) {
      doc.fontSize(14).fillColor('#10B981').font('Helvetica-Bold');
      doc.text('Payment Information', 50, doc.y);
      doc.moveDown(0.5);
      doc.fontSize(11).fillColor('#000000').font('Helvetica');
      doc.text(`Method: ${invoice.paymentMethod}`, 50, doc.y);
      if (invoice.paymentReference) {
        doc.text(`Reference: ${invoice.paymentReference}`, 50, doc.y);
      }
      if (invoice.receivedBy) {
        doc.text(`Received By: ${invoice.receivedBy}`, 50, doc.y);
      }
      doc.moveDown(1);
    }

    // Attachments List
    if (invoice.attachments && invoice.attachments.length > 0) {
      doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
      doc.text('Attachments', 50, doc.y);
      doc.moveDown(0.5);
      doc.fontSize(10).fillColor('#000000').font('Helvetica');

      invoice.attachments.forEach((att: any) => {
        const type = att.type === 'payment_receipt' ? 'Payment Receipt' : 'Service Document';
        const date = new Date(att.uploadedAt).toLocaleDateString('en-GB');
        doc.text(`• ${type} - Uploaded: ${date}`, 50, doc.y);
      });
      doc.moveDown(1);
    }

    // Add footer
    addFooter(doc, company, 1);

    // Finalize PDF
    doc.end();
  } catch (error: any) {
    console.error('Generate invoice PDF error:', error);
    if (!res.headersSent) {
      res.status(500).json({
        success: false,
        error: error.message || 'Failed to generate invoice PDF',
      });
    }
  }
};

/**
 * Generate Expenses List PDF
 */
export const generateExpensesPDF = async (req: AuthRequest, res: Response) => {
  try {
    // Fetch all expenses for the company
    const expenses = await Expense.find({ companyId: req.companyId })
      .populate('createdBy')
      .sort({ date: -1 });

    // Fetch company
    const company = await Company.findById(req.companyId);
    if (!company) {
      return res.status(404).json({
        success: false,
        error: 'Company not found',
      });
    }

    // Create PDF document
    const doc = new PDFDocument({ margin: 50, size: 'A4' });

    // Set response headers
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', 'attachment; filename=expenses-report.pdf');

    // Pipe PDF to response
    doc.pipe(res);

    // Add header
    addCompanyHeader(doc, company, 'Expenses Report');

    doc.moveDown(2);

    // Summary
    const totalExpenses = expenses.reduce((sum, exp) => sum + exp.amount, 0);
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text(`Total Expenses: ${totalExpenses.toLocaleString()} RWF`, 50, doc.y);
    doc.text(`Count: ${expenses.length} expenses`, 50, doc.y);
    doc.moveDown(1.5);

    // Table header
    doc.fontSize(11).fillColor('#000000').font('Helvetica-Bold');
    const tableTop = doc.y;
    doc.text('Date', 50, tableTop);
    doc.text('Supplier', 120, tableTop);
    doc.text('Category', 240, tableTop);
    doc.text('Amount', 340, tableTop);
    doc.text('Created By', 420, tableTop);

    // Draw line under header
    doc.moveTo(50, tableTop + 15).lineTo(550, tableTop + 15).stroke();

    let yPos = tableTop + 25;

    // Table rows
    doc.fontSize(10).font('Helvetica');
    expenses.forEach((expense, index) => {
      // Check if we need a new page
      if (yPos > 700) {
        addFooter(doc, company, Math.floor(index / 30) + 1);
        doc.addPage();
        addCompanyHeader(doc, company, 'Expenses Report (cont.)');
        yPos = 120;
      }

      const date = new Date(expense.date).toLocaleDateString('en-GB', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      });
      const supplier = expense.supplier.length > 15 ? expense.supplier.substring(0, 15) + '...' : expense.supplier;
      const category = expense.category;
      const amount = `${expense.amount.toLocaleString()} ${expense.currency}`;
      const createdBy = (expense.createdBy as any)?.name || 'N/A';

      doc.text(date, 50, yPos);
      doc.text(supplier, 120, yPos);
      doc.text(category, 240, yPos);
      doc.text(amount, 340, yPos);
      doc.text(createdBy.substring(0, 15), 420, yPos);

      yPos += 20;
    });

    // Add total at bottom
    doc.moveDown(2);
    doc.fontSize(12).font('Helvetica-Bold').fillColor(company.brandSecondaryColor || '#10B981');
    doc.text(`Grand Total: ${totalExpenses.toLocaleString()} RWF`, 340, yPos + 10);

    // Add footer
    addFooter(doc, company, 1);

    // Finalize PDF
    doc.end();
  } catch (error: any) {
    console.error('Generate expenses PDF error:', error);
    if (!res.headersSent) {
      res.status(500).json({
        success: false,
        error: error.message || 'Failed to generate expenses PDF',
      });
    }
  }
};

/**
 * Generate Dashboard Summary PDF
 */
export const generateSummaryPDF = async (req: AuthRequest, res: Response) => {
  try {
    // Fetch company
    const company = await Company.findById(req.companyId);
    if (!company) {
      return res.status(404).json({
        success: false,
        error: 'Company not found',
      });
    }

    // Fetch invoices statistics
    const allInvoices = await Invoice.find({ companyId: req.companyId }).populate('clientId');
    const totalInvoices = allInvoices.length;
    const paidInvoices = allInvoices.filter((inv) => inv.status === 'paid');
    const paidAmount = paidInvoices.reduce((sum, inv) => sum + inv.totalAmount, 0);
    const pendingInvoices = allInvoices.filter((inv) => inv.status === 'sent');
    const pendingAmount = pendingInvoices.reduce((sum, inv) => sum + inv.totalAmount, 0);
    const overdueInvoices = allInvoices.filter((inv) => inv.status === 'overdue');
    const overdueAmount = overdueInvoices.reduce((sum, inv) => sum + inv.totalAmount, 0);

    // Fetch expenses statistics
    const allExpenses = await Expense.find({ companyId: req.companyId }).populate('createdBy');
    const totalExpenses = allExpenses.reduce((sum, exp) => sum + exp.amount, 0);

    // Calculate net income
    const netIncome = paidAmount - totalExpenses;

    // Latest 5 invoices and expenses
    const latestInvoices = allInvoices.slice(0, 5);
    const latestExpenses = allExpenses.slice(0, 5);

    // Create PDF document
    const doc = new PDFDocument({ margin: 50, size: 'A4' });

    // Set response headers
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', 'attachment; filename=financial-summary.pdf');

    // Pipe PDF to response
    doc.pipe(res);

    // Add header
    addCompanyHeader(doc, company, 'Financial Summary');

    doc.moveDown(2);

    // Financial Overview
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text('Financial Overview', 50, doc.y);
    doc.moveDown(1);

    doc.fontSize(11).fillColor('#000000').font('Helvetica');
    doc.text(`Total Invoices: ${totalInvoices}`, 50, doc.y);
    doc.text(`Paid Amount: ${paidAmount.toLocaleString()} ${company.defaultCurrency}`, 50, doc.y);
    doc.fillColor('#F59E0B').text(`Pending Amount: ${pendingAmount.toLocaleString()} ${company.defaultCurrency}`, 50, doc.y);
    doc.fillColor('#EF4444').text(`Overdue Amount: ${overdueAmount.toLocaleString()} ${company.defaultCurrency}`, 50, doc.y);
    doc.fillColor('#000000').text(`Total Expenses: ${totalExpenses.toLocaleString()} ${company.defaultCurrency}`, 50, doc.y);

    doc.moveDown(0.5);
    doc.fontSize(12).font('Helvetica-Bold').fillColor(netIncome >= 0 ? '#10B981' : '#EF4444');
    doc.text(`Net Income: ${netIncome.toLocaleString()} ${company.defaultCurrency}`, 50, doc.y);

    doc.moveDown(2);

    // Latest Invoices
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text('Recent Invoices (Top 5)', 50, doc.y);
    doc.moveDown(1);

    if (latestInvoices.length > 0) {
      doc.fontSize(10).fillColor('#000000').font('Helvetica');
      latestInvoices.forEach((invoice) => {
        const clientName = (invoice.clientId as any)?.name || 'N/A';
        const status = invoice.status.toUpperCase();
        const amount = `${invoice.totalAmount.toLocaleString()} ${invoice.currency}`;
        doc.text(`• ${invoice.invoiceNumber} - ${clientName} - ${status} - ${amount}`, 50, doc.y);
      });
    } else {
      doc.fontSize(10).fillColor('#666666').font('Helvetica-Oblique');
      doc.text('No invoices yet', 50, doc.y);
    }

    doc.moveDown(2);

    // Latest Expenses
    doc.fontSize(14).fillColor(company.brandColor || '#2563EB').font('Helvetica-Bold');
    doc.text('Recent Expenses (Top 5)', 50, doc.y);
    doc.moveDown(1);

    if (latestExpenses.length > 0) {
      doc.fontSize(10).fillColor('#000000').font('Helvetica');
      latestExpenses.forEach((expense) => {
        const date = new Date(expense.date).toLocaleDateString('en-GB');
        const amount = `${expense.amount.toLocaleString()} ${expense.currency}`;
        doc.text(`• ${date} - ${expense.supplier} - ${expense.category} - ${amount}`, 50, doc.y);
      });
    } else {
      doc.fontSize(10).fillColor('#666666').font('Helvetica-Oblique');
      doc.text('No expenses yet', 50, doc.y);
    }

    // Add footer
    addFooter(doc, company, 1);

    // Finalize PDF
    doc.end();
  } catch (error: any) {
    console.error('Generate summary PDF error:', error);
    if (!res.headersSent) {
      res.status(500).json({
        success: false,
        error: error.message || 'Failed to generate summary PDF',
      });
    }
  }
};
